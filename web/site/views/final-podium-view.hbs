<!DOCTYPE html>
<html lang="pt-pt">
<head>
    <meta charset="UTF-8">
    <title>GIFWARS - Pódio Final</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="p-4 md:p-8">

    {{> header}}

    <span id="room-code-display" class="hidden">{{room.code}}</span>

    <main class="max-w-4xl mx-auto mt-10 text-center space-y-12">
        
        <div class="space-y-4">
            <h2 class="text-7xl font-black italic text-transparent bg-clip-text bg-gradient-to-b from-white to-gray-500 uppercase tracking-tighter leading-none">CAMPEONATO</h2>
            <p class="text-yellow-500 font-black uppercase tracking-[0.8em] text-[10px]">A Arena Curva-se aos Vencedores</p>
        </div>

        <!-- Pódio Visual -->
        <div class="flex flex-col md:flex-row items-end justify-center gap-4 px-4 h-[400px]">
            {{#if podium.[1]}}
            <div class="flex-1 flex flex-col items-center">
                <div class="w-16 h-16 rounded-full bg-gray-400 flex items-center justify-center font-black text-xl text-black mb-4 shadow-xl">2</div>
                <div class="glass w-full p-6 rounded-t-3xl border-t border-white/10 bg-gray-400/10 h-[150px] flex flex-col items-center justify-center">
                    <img src="/images/pfp-{{podium.[1].pfp}}.jpeg" class="w-12 h-12 mb-2 object-contain">
                    <span class="font-black italic uppercase text-white truncate w-full px-2">{{podium.[1].name}}</span>
                    <span class="text-gray-400 font-black text-sm">{{podium.[1].score}} PTS</span>
                </div>
            </div>
            {{/if}}

            {{#if podium.[0]}}
            <div class="flex-1 flex flex-col items-center scale-110 relative z-10">
                <div class="absolute -top-10 animate-bounce"><i data-lucide="crown" class="w-10 h-10 text-yellow-500"></i></div>
                <div class="w-20 h-20 rounded-full bg-yellow-500 flex items-center justify-center font-black text-3xl text-black mb-4 shadow-2xl">1</div>
                <div class="glass w-full p-8 rounded-t-[40px] border-t-2 border-yellow-500/50 bg-yellow-500/10 h-[220px] flex flex-col items-center justify-center">
                    <img src="/images/pfp-{{podium.[0].pfp}}.jpeg" class="w-16 h-16 mb-4 object-contain">
                    <span class="text-2xl font-black italic uppercase text-white truncate w-full px-2">{{podium.[0].name}}</span>
                    <span class="text-yellow-500 font-black text-xl">{{podium.[0].score}} PTS</span>
                </div>
            </div>
            {{/if}}

            {{#if podium.[2]}}
            <div class="flex-1 flex flex-col items-center">
                <div class="w-16 h-16 rounded-full bg-orange-700 flex items-center justify-center font-black text-xl text-black mb-4 shadow-xl">3</div>
                <div class="glass w-full p-6 rounded-t-3xl border-t border-white/10 bg-orange-700/10 h-[100px] flex flex-col items-center justify-center">
                    <img src="/images/pfp-{{podium.[2].pfp}}.jpeg" class="w-10 h-10 mb-1 object-contain">
                    <span class="font-black italic uppercase text-white truncate w-full px-2">{{podium.[2].name}}</span>
                    <span class="text-orange-700 font-black text-sm">{{podium.[2].score}} PTS</span>
                </div>
            </div>
            {{/if}}
        </div>

        <!-- Botão Novo Campeonato em cima da tabela -->
        <div class="py-8">
            {{#if isHost}}
                <form action="/game/restart" method="POST">
                    <button type="submit" class="bg-white text-black px-16 py-5 rounded-[32px] font-black text-xl hover:bg-purple-600 hover:text-white transition-all shadow-2xl uppercase tracking-tighter italic active:scale-95 group">
                        <span class="flex items-center gap-3">
                            <i data-lucide="refresh-cw" class="w-5 h-5 group-hover:rotate-180 transition-transform duration-500"></i>
                            NOVO CAMPEONATO
                        </span>
                    </button>
                </form>
            {{else}}
                <p class="text-gray-500 font-black uppercase tracking-widest text-[10px] italic animate-pulse">A aguardar que o Host reinicie a Arena...</p>
            {{/if}}
        </div>

        <!-- Tabela de Classificação Completa -->
        <div class="glass p-8 md:p-12 rounded-[48px] border border-white/5 bg-white/5 text-left relative overflow-hidden">
            <h3 class="text-[10px] font-black text-gray-500 uppercase tracking-[0.5em] mb-10 italic">Classificação Geral</h3>
            <div class="space-y-3">
                {{#each podium}}
                <div class="flex items-center justify-between p-5 rounded-3xl transition-all {{#if (eq (string this.id) (string ../player.id))}}bg-purple-600/20 border border-purple-500/30 shadow-lg{{else}}bg-black/20 border border-white/5{{/if}}">
                    <div class="flex items-center gap-6">
                        <span class="w-8 text-center font-black text-xl italic {{#if (eq @index 0)}}text-yellow-500{{else if (eq @index 1)}}text-gray-400{{else if (eq @index 2)}}text-orange-700{{else}}text-gray-600{{/if}}">#{{add @index 1}}</span>
                        <div class="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center p-1">
                            <img src="/images/pfp-{{this.pfp}}.jpeg" class="w-full h-full object-contain">
                        </div>
                        <span class="font-black italic uppercase text-white">{{this.name}} {{#if (eq (string this.id) (string ../player.id))}}<span class="ml-2 text-[8px] bg-purple-500 text-white px-2 py-0.5 rounded-full not-italic">TU</span>{{/if}}</span>
                    </div>
                    <span class="text-2xl font-black italic text-white">{{this.score}} <span class="text-[8px] text-gray-500 uppercase not-italic">pts</span></span>
                </div>
                {{/each}}
            </div>
        </div>

    </main>

    {{> footer}}
</body>
</html>