<!DOCTYPE html>
<html lang="pt-pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GIFWARS - Aguardando Outros Votos</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="p-4 md:p-8">

    {{> header}}

    <span id="room-code-display" class="hidden">{{room.code}}</span>

    <main class="max-w-4xl mx-auto mt-20 text-center">
        <div class="glass p-16 rounded-[48px] border-t border-white/10 shadow-2xl relative overflow-hidden max-w-2xl mx-auto">
            <div class="absolute inset-0 bg-purple-600/5 animate-pulse"></div>
            
            <div class="relative z-10">
                <!-- TIMER ADICIONADO AQUI DENTRO -->
                <div class="mb-6 flex justify-center">
                    <div class="px-4 py-1 bg-purple-500/20 rounded-full border border-purple-500/30">
                        <span id="timer" class="text-xl font-black text-purple-400">--</span>
                    </div>
                </div>

                <div class="mb-10 flex justify-center">
                    <div class="p-5 bg-purple-500/10 rounded-full shadow-inner">
                        <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-500"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                    </div>
                </div>

                <h2 class="text-4xl font-black mb-4 italic uppercase tracking-tighter">Voto Registado!</h2>
                <p class="text-gray-400 text-lg mb-10 italic">Agora relaxa. Estamos a ver quem ganha esta batalha de temas...</p>

                <div class="flex flex-col items-center gap-6">
                    <div class="flex gap-2">
                        <div class="w-3 h-3 bg-purple-500 rounded-full animate-bounce"></div>
                        <div class="w-3 h-3 bg-purple-500 rounded-full animate-bounce [animation-delay:-0.15s]"></div>
                        <div class="w-3 h-3 bg-purple-500 rounded-full animate-bounce [animation-delay:-0.3s]"></div>
                    </div>
                    
                    <div class="glass px-8 py-3 rounded-2xl border-white/5 bg-white/5">
                        <p class="text-[10px] font-black text-gray-500 uppercase tracking-[0.3em]">Aguardando outros jogadores</p>
                    </div>
                </div>
            </div>
        </div>
    </main>

    {{> footer}}

    <script src="/socket.io/socket.io.js"></script>
    <script>
        (function() {
            const timerElement = document.getElementById('timer');
            let timeLeft = parseInt("{{timeLeft}}") || 0;

            function updateDisplay() {
                const mins = Math.floor(Math.max(0, timeLeft) / 60);
                const secs = Math.floor(Math.max(0, timeLeft) % 60);
                timerElement.innerText = `${mins}:${secs < 10 ? '0' : ''}${secs}`;
            }

            updateDisplay();

            const interval = setInterval(() => {
                timeLeft--;
                updateDisplay();

                if (timeLeft <= 0) {
                    clearInterval(interval);
                    {{#if isHost}}
                        fetch('/theme/vote-auto-finish', { method: 'POST' });
                    {{/if}}
                }
            }, 1000);

            try {
                const socket = io();
                socket.emit('join_room_socket', '{{room.code}}');
                socket.on('room_sync', (data) => {
                    if (data.type === 'state_update') window.location.reload();
                });
            } catch (e) {}
        })();
    </script>
</body>
</html>