<header class="max-w-5xl mx-auto flex justify-between items-center mb-6 pt-8 px-4">
    <div class="flex flex-col">
        <a href="/" class="hover:opacity-80 transition-opacity">
            <h1 class="text-4xl font-black tracking-tighter text-purple-400 leading-none italic">
                GIF<span class="text-white">WARS</span>
            </h1>
        </a>
        <div class="flex items-center gap-3 mt-2">
            <span class="bg-purple-600/20 text-purple-400 px-3 py-1 rounded-lg text-[10px] font-black uppercase tracking-widest border border-purple-500/20">
                Arena 2026
            </span>
            {{#if room}}
                <div class="flex items-center gap-2">
                    <i data-lucide="layers" class="w-3 h-3 text-gray-600"></i>
                    <span class="text-gray-500 text-[10px] font-black uppercase tracking-widest italic">
                        Ronda {{room.round}} de {{room.configs.rounds}}
                    </span>
                </div>
            {{/if}}
        </div>
    </div>

    <div class="flex items-center gap-5">
        <div class="flex flex-col items-end">
            <span class="text-white font-black italic uppercase tracking-tighter text-lg leading-none">
                {{player.name}}
            </span>
            <div class="flex items-center gap-1.5 mt-1">
                <span class="text-purple-400 text-[10px] font-black uppercase tracking-widest">
                    {{player.score}}
                </span>
                <span class="text-gray-600 text-[8px] font-black uppercase tracking-widest">
                    PTS
                </span>
            </div>
        </div>
        
        <!-- LINK PARA PERFIL COM ÍCONE DE USER -->
        <a href="/profile" class="glass w-14 h-14 rounded-2xl border border-white/10 flex items-center justify-center shadow-2xl relative group overflow-hidden hover:border-purple-500 transition-colors" title="O Teu Perfil">
            <div class="absolute inset-0 bg-gradient-to-tr from-purple-600/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
            <!-- Ícone alterado de 'shield' para 'user' -->
            <i data-lucide="user" class="w-7 h-7 text-white group-hover:text-purple-400 transition-all duration-300 relative z-10"></i>
            <div class="w-2 h-2 rounded-full bg-green-500 absolute top-3 right-3 shadow-[0_0_8px_rgba(34,197,94,0.5)]"></div>
        </a>
    </div>
</header>