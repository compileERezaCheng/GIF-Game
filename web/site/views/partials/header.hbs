<header class="max-w-5xl mx-auto flex justify-between items-center mb-6 pt-8 px-4">
    <div class="flex flex-col">
        <!-- Logo Sempre Visível -->
        <a href="/" class="hover:opacity-80 transition-opacity">
            <h1 class="text-4xl font-black tracking-tighter text-purple-400 leading-none italic uppercase">
                GIF<span class="text-white">WARS</span>
            </h1>
        </a>
        
        <!-- Info da Ronda (Só aparece DENTRO de uma sala) -->
        {{#if room}}
        <div class="flex items-center gap-3 mt-2">
            <span class="bg-purple-600/20 text-purple-400 px-3 py-1 rounded-lg text-[10px] font-black uppercase tracking-widest border border-purple-500/20 italic">
                Arena 2026
            </span>
            <div class="flex items-center gap-2">
                <i data-lucide="layers" class="w-3 h-3 text-gray-600"></i>
                <span class="text-gray-500 text-[10px] font-black uppercase tracking-widest italic">
                    Ronda {{room.round}} de {{room.configs.rounds}}
                </span>
            </div>
        </div>
        {{/if}}
    </div>

    <!-- Perfil e Ações -->
    {{#if player}}
    <div class="flex items-center gap-4">
        <div class="flex flex-col items-end">
            <span class="text-white font-black italic uppercase tracking-tighter text-lg leading-none">
                {{player.name}}
            </span>
            <div class="flex items-center gap-1.5 mt-1">
                <span class="text-purple-400 text-[10px] font-black uppercase tracking-widest">{{player.score}}</span>
                <span class="text-gray-600 text-[8px] font-black uppercase tracking-widest">PTS</span>
            </div>
        </div>
        
        <div class="flex items-center gap-3">
            <div class="relative">
                <!-- Lógica Condicional do Botão de Perfil -->
                {{#if room}}
                    {{#if (eq room.status 'LOBBY')}}
                        <a href="/profile" class="glass w-12 h-12 rounded-xl border border-white/10 flex items-center justify-center shadow-2xl relative group overflow-hidden hover:border-purple-500 transition-colors" title="O Teu Perfil">
                            <div class="absolute inset-0 bg-gradient-to-tr from-purple-600/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                            <img src="/images/pfp-{{player.pfp}}.png" class="w-8 h-8 object-contain relative z-10 transition-transform group-hover:scale-110" alt="Avatar" onerror="this.src='https://placehold.co/100?text=Avatar'">
                        </a>
                    {{else}}
                        <div class="glass w-12 h-12 rounded-xl border border-white/10 flex items-center justify-center shadow-2xl relative overflow-hidden opacity-50 cursor-not-allowed">
                            <img src="/images/pfp-{{player.pfp}}.png" class="w-8 h-8 object-contain relative z-10 grayscale-[30%]" alt="Avatar">
                        </div>
                    {{/if}}
                {{else}}
                    <a href="/profile" class="glass w-12 h-12 rounded-xl border border-white/10 flex items-center justify-center shadow-2xl relative group overflow-hidden hover:border-purple-500 transition-colors" title="O Teu Perfil">
                        <div class="absolute inset-0 bg-gradient-to-tr from-purple-600/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                        <img src="/images/pfp-{{player.pfp}}.png" class="w-8 h-8 object-contain relative z-10 transition-transform group-hover:scale-110" alt="Avatar">
                    </a>
                {{/if}}
                <span class="absolute -bottom-1 -right-1 w-3.5 h-3.5 bg-green-500 border-2 border-[#1e1b4b] rounded-full z-20 shadow-[0_0_8px_rgba(34,197,94,0.6)]"></span>
            </div>

            <!-- Ícone para Sair do Jogo -->
            {{#if room}}
            <form action="/room/leave" method="POST" class="flex items-center">
                <button type="submit" class="p-2.5 rounded-xl glass border border-white/5 text-gray-500 hover:text-red-500 hover:border-red-500/30 transition-all active:scale-90" title="Sair da Sala">
                    <i data-lucide="log-out" class="w-5 h-5"></i>
                </button>
            </form>
            {{/if}}
        </div>
    </div>
    {{/if}}
</header>