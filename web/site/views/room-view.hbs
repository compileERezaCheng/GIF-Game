<!DOCTYPE html>
<html lang="pt-pt">
<head>
    <meta charset="UTF-8">
    <title>GIFWARS - Sala de Espera</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="p-4 md:p-8">

    {{> header}}

    <span id="room-code-display" class="hidden">{{room.code}}</span>

    <main class="max-w-4xl mx-auto space-y-8">
        
        <div class="glass p-10 rounded-3xl text-center border-t border-white/10 relative overflow-hidden">
            <div class="relative z-10">
                
                <div class="flex justify-between items-start mb-6">
                    <div class="w-10"></div> <!-- Spacer -->
                    <div class="inline-flex p-4 bg-purple-500/10 rounded-2xl">
                        <i data-lucide="gamepad-2" class="text-purple-500 w-10 h-10"></i>
                    </div>
                    <!-- BOTÃO PARA SAIR DA SALA -->
                    <form action="/room/leave" method="POST">
                        <button type="submit" class="p-3 hover:bg-red-500/20 rounded-2xl transition-all text-red-500 group" title="Sair da Sala">
                            <i data-lucide="log-out" class="w-6 h-6 group-hover:scale-110"></i>
                        </button>
                    </form>
                </div>
                
                <h2 class="text-3xl font-black mb-2 italic uppercase">Sala de Espera</h2>
                <p class="text-gray-400 text-sm mb-8 italic">Código da Sala:</p>

                <div class="max-w-xs mx-auto mb-10">
                    <div class="bg-black/30 p-6 rounded-3xl border-2 border-purple-500/30 shadow-2xl relative">
                        <div class="flex items-center justify-center gap-4">
                            <span id="room-code-text" class="text-5xl font-black text-white tracking-tighter">{{room.code}}</span>
                            <button onclick="copyRoomCode()" class="p-3 hover:bg-white/10 rounded-2xl transition-all text-purple-400">
                                <i data-lucide="copy" class="w-6 h-6"></i>
                            </button>
                        </div>
                    </div>
                </div>

                {{#if isHost}}
                    <div class="max-w-xl mx-auto glass p-8 rounded-3xl border-purple-500/40 bg-purple-500/5">
                        <h4 class="text-xs font-bold text-purple-400 uppercase tracking-widest mb-6 flex items-center justify-center gap-2">
                            <i data-lucide="settings" class="w-4 h-4"></i> Definições da Partida
                        </h4>
                        <form action="/game/start" method="POST" class="space-y-6">
                            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                                <div class="bg-black/40 p-3 rounded-xl border border-white/10">
                                    <label class="text-[9px] text-gray-500 uppercase font-black block mb-1">Rondas</label>
                                    <input type="number" name="rounds" value="{{room.configs.rounds}}" min="1" max="10" class="w-full bg-transparent text-white font-black outline-none text-center text-xl">
                                </div>
                                <div class="bg-black/40 p-3 rounded-xl border border-white/10">
                                    <label class="text-[9px] text-gray-500 uppercase font-black block mb-1">Temas (Min)</label>
                                    <input type="number" name="suggestionTime" value="{{room.configs.suggestionTime}}" min="1" max="5" class="w-full bg-transparent text-white font-black outline-none text-center text-xl">
                                </div>
                                <div class="bg-black/40 p-3 rounded-xl border border-white/10">
                                    <label class="text-[9px] text-gray-500 uppercase font-black block mb-1">GIFs (Min)</label>
                                    <input type="number" name="submissionTime" value="{{room.configs.submissionTime}}" min="1" max="5" class="w-full bg-transparent text-white font-black outline-none text-center text-xl">
                                </div>
                            </div>
                            
                            <!-- Botão atualizado com ID e classes 'disabled:' do Tailwind -->
                            <button id="start-btn" type="submit" class="w-full bg-green-600 hover:bg-green-700 disabled:bg-gray-700 disabled:text-gray-500 disabled:cursor-not-allowed disabled:shadow-none text-white py-4 rounded-2xl font-black text-lg shadow-lg shadow-green-900/30 uppercase italic transition-all duration-300">
                                COMEÇAR BATALHA
                            </button>
                            <!-- Fim da atualização do botão -->

                        </form>
                    </div>
                {{else}}
                    <div class="max-w-sm mx-auto py-12">
                        <div class="flex flex-col items-center gap-6">
                            <div class="flex gap-3">
                                <div class="w-4 h-4 bg-purple-500 rounded-full animate-bounce"></div>
                                <div class="w-4 h-4 bg-purple-500 rounded-full animate-bounce [animation-delay:-0.15s]"></div>
                                <div class="w-4 h-4 bg-purple-500 rounded-full animate-bounce [animation-delay:-0.3s]"></div>
                            </div>
                            <p class="text-purple-400 font-black text-xl italic uppercase tracking-tight">A aguardar sinal do Host...</p>
                        </div>
                    </div>
                {{/if}}
            </div>
        </div>

        <div class="glass p-8 rounded-3xl shadow-xl">
            <h3 class="font-black text-2xl mb-8 uppercase italic flex items-center gap-3">
                <i data-lucide="users" class="w-8 h-8 text-purple-400"></i> GUERREIROS (<span id="player-count">{{players.length}}</span>)
            </h3>
            <div id="player-list-container" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                {{#each players}}
                    <div class="flex items-center gap-4 p-5 bg-white/5 border border-white/5 rounded-3xl group">
                        <div class="w-14 h-14 rounded-2xl bg-black/40 flex items-center justify-center p-2 shadow-lg">
                            <img src="/images/pfp-{{this.pfp}}.jpeg" class="w-full h-full object-contain">
                        </div>
                        <div class="flex flex-col">
                            <span class="font-bold text-lg text-white">{{this.name}}</span>
                            {{#if (eq (string this.id) (string ../room.hostId))}}
                                <span class="text-[9px] uppercase font-black text-yellow-500">Host da Sala</span>
                            {{else}}
                                <span class="text-[9px] uppercase font-bold text-gray-500">Pronto</span>
                            {{/if}}
                        </div>
                    </div>
                {{/each}}
            </div>
        </div>
    </main>

    {{> footer}}

    <script>
        function copyRoomCode() {
            const code = document.getElementById('room-code-text').innerText;
            navigator.clipboard.writeText(code).then(() => {
                if (typeof showToast === 'function') showToast("Código copiado!");
            });
        }

        // Validação inicial ao carregar a página
        document.addEventListener('DOMContentLoaded', () => {
            const initialPlayerCount = {{players.length}};
            const startBtn = document.getElementById('start-btn');
            if (startBtn) {
                startBtn.disabled = initialPlayerCount < 2;
            }
        });

        socket.on('room_sync', (data) => {
            if (data.type === 'player_update') {
                const container = document.getElementById('player-list-container');
                const count = document.getElementById('player-count');
                const startBtn = document.getElementById('start-btn'); // Referência ao botão
                
                if (count) count.innerText = data.players.length;
                
                // Desativa o botão em tempo real se a sala tiver menos de 2 jogadores
                if (startBtn) {
                    startBtn.disabled = data.players.length < 2;
                }

                if (container) {
                    container.innerHTML = data.players.map(p => `
                        <div class="flex items-center gap-4 p-5 bg-white/5 border border-white/5 rounded-3xl animate-in fade-in duration-500">
                            <div class="w-14 h-14 rounded-2xl bg-black/40 flex items-center justify-center p-2">
                                <img src="/images/pfp-${p.pfp}.jpeg" class="w-full h-full object-contain">
                            </div>
                            <div class="flex flex-col">
                                <span class="font-bold text-lg text-white">${p.name}</span>
                                ${String(p.id) === "{{room.hostId}}" ? '<span class="text-[9px] uppercase font-black text-yellow-500">Host da Sala</span>' : '<span class="text-[9px] uppercase font-bold text-gray-500">Pronto</span>'}
                            </div>
                        </div>
                    `).join('');
                }
            } else if (data.type === 'state_update') {
                window.location.reload();
            }
        });
    </script>
</body>
</html>