<!DOCTYPE html>
<html lang="pt-pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GIFWARS - Sala de Espera</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="p-4 md:p-8">

    {{> header}}

    <!-- Span invisível para o Socket saber em que sala estamos -->
    <span id="room-code-display" class="hidden">{{room.code}}</span>

    <main class="max-w-4xl mx-auto space-y-8">
        
        <!-- Painel Central com Código da Sala -->
        <div class="glass p-10 rounded-3xl text-center border-t border-white/10 relative overflow-hidden">
            <div class="relative z-10">
                <div class="inline-flex p-4 bg-purple-500/10 rounded-2xl mb-6">
                    <i data-lucide="gamepad-2" class="text-purple-500 w-10 h-10"></i>
                </div>
                
                <h2 class="text-3xl font-black mb-2 italic uppercase">Sala de Espera</h2>
                <p class="text-gray-400 text-sm mb-8 italic">Partilha o código abaixo com os teus amigos:</p>

                <!-- Bloco do Código com Botão de Copiar -->
                <div class="max-w-xs mx-auto mb-10">
                    <div class="bg-black/30 p-6 rounded-3xl border-2 border-purple-500/30 shadow-2xl relative group">
                        <div class="flex items-center justify-center gap-4">
                            <span id="room-code-text" class="text-5xl font-black tracking-tighter text-white">{{room.code}}</span>
                            <button onclick="copyRoomCode()" class="p-3 hover:bg-white/10 rounded-2xl transition-all text-purple-400 hover:text-white" title="Copiar Código">
                                <i data-lucide="copy" class="w-6 h-6"></i>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- VERIFICAÇÃO DE HOST: Apenas o Host vê e altera as definições -->
                {{#if isHost}}
                    <div class="max-w-xl mx-auto glass p-8 rounded-3xl border-purple-500/40 bg-purple-500/5">
                        <h4 class="text-xs font-bold text-purple-400 uppercase tracking-widest mb-6 flex items-center justify-center gap-2">
                            <i data-lucide="settings" class="w-4 h-4"></i> Definições da Partida
                        </h4>
                        <form action="/game/start" method="POST" class="space-y-6">
                            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                                <!-- Rondas -->
                                <div class="bg-black/40 p-3 rounded-xl border border-white/10 focus-within:border-purple-500 transition-all">
                                    <label class="text-[9px] text-gray-500 uppercase font-black block mb-1 text-left">Rondas</label>
                                    <input type="number" name="rounds" value="{{room.configs.rounds}}" min="1" max="10" 
                                        class="w-full bg-transparent text-white font-black outline-none text-center text-xl">
                                </div>
                                <!-- Tempo para Temas -->
                                <div class="bg-black/40 p-3 rounded-xl border border-white/10 focus-within:border-purple-500 transition-all">
                                    <label class="text-[9px] text-gray-500 uppercase font-black block mb-1 text-left">Sugerir (Min)</label>
                                    <input type="number" name="suggestionTime" value="{{room.configs.suggestionTime}}" min="1" max="5" 
                                        class="w-full bg-transparent text-white font-black outline-none text-center text-xl">
                                </div>
                                <!-- Tempo para GIFs (Novo) -->
                                <div class="bg-black/40 p-3 rounded-xl border border-white/10 focus-within:border-purple-500 transition-all">
                                    <label class="text-[9px] text-gray-500 uppercase font-black block mb-1 text-left">Escolher GIF (Min)</label>
                                    <input type="number" name="submissionTime" value="{{room.configs.submissionTime}}" min="1" max="10" 
                                        class="w-full bg-transparent text-white font-black outline-none text-center text-xl">
                                </div>
                            </div>
                            
                            <button type="submit" class="w-full bg-green-600 hover:bg-green-700 text-white py-4 rounded-2xl font-black text-lg shadow-lg shadow-green-900/30 transition-all active:scale-95 uppercase italic tracking-tighter">
                                COMEÇAR BATALHA
                            </button>
                        </form>
                    </div>
                {{else}}
                    <!-- O QUE OS JOGADORES VÊEM: Apenas o estado de espera -->
                    <div class="max-w-sm mx-auto py-12">
                        <div class="flex flex-col items-center gap-6">
                            <div class="flex gap-3">
                                <div class="w-4 h-4 bg-purple-500 rounded-full animate-bounce"></div>
                                <div class="w-4 h-4 bg-purple-500 rounded-full animate-bounce [animation-delay:-0.15s]"></div>
                                <div class="w-4 h-4 bg-purple-500 rounded-full animate-bounce [animation-delay:-0.3s]"></div>
                            </div>
                            <p class="text-purple-400 font-black text-xl italic tracking-tight uppercase">A aguardar sinal do Host...</p>
                        </div>
                    </div>
                {{/if}}
            </div>
        </div>

        <!-- Lista de Jogadores Dinâmica -->
        <div class="glass p-8 rounded-3xl shadow-xl">
            <h3 class="font-black text-2xl flex items-center gap-3 italic mb-8 uppercase tracking-tighter">
                <i data-lucide="users" class="w-8 h-8 text-purple-400"></i> 
                GUERREIROS (<span id="player-count">{{players.length}}</span>)
            </h3>
            
            <div id="player-list-container" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                {{#each players}}
                    <div class="flex items-center justify-between p-5 bg-white/5 border border-white/5 rounded-3xl hover:bg-white/10 transition-all group">
                        <div class="flex items-center gap-4">
                            <div class="w-12 h-12 rounded-2xl bg-gradient-to-tr from-purple-600 to-pink-500 flex items-center justify-center font-black text-xl shadow-lg group-hover:rotate-6 transition-transform">
                                {{slice this.name 0 1}}
                            </div>
                            <div class="flex flex-col text-left">
                                <span class="font-bold text-lg leading-tight">{{this.name}}</span>
                                {{#if (eq this.id ../room.hostId)}}
                                    <span class="text-[9px] uppercase font-black text-yellow-500 tracking-widest mt-0.5">Host da Sala</span>
                                {{else}}
                                    <span class="text-[9px] uppercase font-bold text-gray-500 tracking-widest mt-0.5">Pronto</span>
                                {{/if}}
                            </div>
                        </div>
                    </div>
                {{/each}}
            </div>
        </div>
    </main>

    {{> footer}}

    <script>
        function copyRoomCode() {
            const code = document.getElementById('room-code-text').innerText;
            const temp = document.createElement('input');
            temp.value = code;
            document.body.appendChild(temp);
            temp.select();
            document.execCommand('copy');
            document.body.removeChild(temp);
            
            if (typeof showToast === 'function') {
                showToast("Código " + code + " copiado!");
            }
        }

        socket.on('room_sync', (data) => {
            if (data.type === 'player_update') {
                const container = document.getElementById('player-list-container');
                const count = document.getElementById('player-count');
                
                if (count) count.innerText = data.players.length;
                if (container) {
                    container.innerHTML = data.players.map(p => `
                        <div class="flex items-center justify-between p-5 bg-white/5 border border-white/5 rounded-3xl animate-in fade-in duration-500">
                            <div class="flex items-center gap-4">
                                <div class="w-12 h-12 rounded-2xl bg-gradient-to-tr from-purple-600 to-pink-500 flex items-center justify-center font-black text-xl shadow-lg">
                                    ${p.name.charAt(0).toUpperCase()}
                                </div>
                                <div class="flex flex-col text-left">
                                    <span class="font-bold text-lg leading-tight text-white">${p.name}</span>
                                    ${p.id === "{{room.hostId}}" ? '<span class="text-[9px] uppercase font-black text-yellow-500 tracking-widest mt-0.5">Host da Sala</span>' : '<span class="text-[9px] uppercase font-bold text-gray-500 tracking-widest mt-0.5">Pronto</span>'}
                                </div>
                            </div>
                        </div>
                    `).join('');
                }
            } 
            else if (data.type === 'state_update') {
                window.location.reload();
            }
        });
    </script>

</body>
</html>