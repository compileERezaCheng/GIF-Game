<!DOCTYPE html>
<html lang="pt-pt">
<head>
    <meta charset="UTF-8">
    <title>GIFWARS - Entrar na Arena</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="p-4 md:p-8 flex items-center justify-center min-h-screen">

    <main class="max-w-xl w-full">
        <div class="glass p-12 rounded-[48px] border-t border-white/10 shadow-2xl relative overflow-hidden text-center">
            
            <h1 class="text-6xl font-black italic text-purple-400 mb-2 tracking-tighter uppercase">GIFWARS</h1>
            <p class="text-gray-500 font-bold uppercase tracking-[0.3em] text-[10px] mb-12 italic">Arena de Batalha 2026</p>

            <!-- A página inicial agora foca apenas no nome para um fluxo mais rápido -->
            <form action="/login" method="POST" class="space-y-10">
                <div class="space-y-4">
                    <label class="text-[10px] font-black text-purple-400 uppercase tracking-widest block italic">Como te vão chamar no campo de batalha?</label>
                    <input type="text" name="name" placeholder="Teu Nome de Guerra..." maxlength="15" required 
                        class="w-full p-6 bg-gray-900 border-2 border-gray-800 rounded-3xl text-white text-center text-2xl font-black focus:border-purple-600 outline-none transition-all">
                </div>

                <button type="submit" class="w-full bg-white text-black p-6 rounded-3xl font-black text-xl hover:bg-purple-600 hover:text-white transition-all shadow-xl active:scale-95 uppercase italic tracking-tight">
                    AVANÇAR PARA OS ÍCONES
                </button>
            </form>
        </div>
    </main>

    <script src="https://unpkg.com/lucide@latest"></script>
    <script>lucide.createIcons();</script>
</body>
</html>