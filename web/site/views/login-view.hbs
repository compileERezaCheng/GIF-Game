<!DOCTYPE html>
<html lang="pt-pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GIFWARS - Login</title>
    <!-- Tailwind CSS para estilização rápida -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- O teu CSS customizado para Glassmorphism -->
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="p-4 md:p-8">

    {{> header}}

    <main class="max-w-4xl mx-auto">
        <!-- Caixa de Login com efeito Glass -->
        <div class="glass max-w-md mx-auto p-10 rounded-3xl text-center mt-20 shadow-2xl border-t border-white/10">
            <div class="mb-6 flex justify-center">
                <i data-lucide="shield-check" class="w-16 h-16 text-purple-500"></i>
            </div>
            
            <h1 class="text-3xl font-black mb-2 italic">ARENA GIFWARS</h1>
            <p class="text-gray-400 mb-8 text-sm">Escolhe o teu nome e prepara-te para a batalha.</p>
            
            <!-- Formulário que comunica com o Website Router -->
            <form action="/login" method="POST" class="space-y-4">
                <div class="relative">
                    <input 
                        type="text" 
                        name="name" 
                        placeholder="Teu nome de guerra..." 
                        required 
                        autofocus
                        class="w-full p-4 bg-gray-800/50 border border-gray-700 rounded-2xl text-white text-center text-lg focus:outline-none focus:ring-2 focus:ring-purple-500 transition-all"
                    >
                </div>
                
                <button type="submit" class="w-full bg-purple-600 hover:bg-purple-700 text-white p-4 rounded-2xl font-bold text-lg shadow-lg shadow-purple-900/40 transition-all active:scale-95">
                    ENTRAR NA ARENA
                </button>
            </form>
        </div>
    </main>

    {{> footer}}

</body>
</html>