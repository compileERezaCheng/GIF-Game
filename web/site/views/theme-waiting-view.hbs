<!DOCTYPE html>
<html lang="pt-pt">
<head>
    <meta charset="UTF-8">
    <title>GIFWARS - Aguardando Temas</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="p-4 md:p-8">

    {{> header}}

    <span id="room-code-display" class="hidden">{{room.code}}</span>

    <main class="max-w-4xl mx-auto mt-10">
        <div class="glass p-10 rounded-[40px] text-center border-t border-white/10 relative overflow-hidden">
            <!-- Background animado subtil -->
            <div class="absolute inset-0 bg-purple-600/5 animate-pulse"></div>

            <div class="relative z-10">
                <div class="mb-8 flex justify-center">
                    <div class="w-24 h-24 rounded-full border-4 border-purple-500/30 flex items-center justify-center bg-black/40 shadow-inner">
                        <span id="timer" class="text-3xl font-black text-purple-400">--</span>
                    </div>
                </div>

                <h2 class="text-3xl font-black mb-4 italic uppercase">Tema Submetido!</h2>
                <p class="text-gray-400 text-lg mb-8">Agora relaxa. Estamos à espera que os teus amigos parem de pensar e escrevam alguma coisa...</p>

                <div class="flex flex-col items-center gap-6">
                    <div class="flex gap-2">
                        <div class="w-3 h-3 bg-purple-500 rounded-full animate-bounce"></div>
                        <div class="w-3 h-3 bg-purple-500 rounded-full animate-bounce [animation-delay:-0.15s]"></div>
                        <div class="w-3 h-3 bg-purple-500 rounded-full animate-bounce [animation-delay:-0.3s]"></div>
                    </div>
                    
                    <div class="glass px-6 py-3 rounded-2xl border-white/5">
                        <p class="text-xs font-bold text-gray-500 uppercase tracking-widest">Aguardando submissões</p>
                    </div>
                </div>
            </div>
        </div>
    </main>

    {{> footer}}

    <script>
        // Cronómetro Sincronizado (usa o tempo que veio do servidor)
        let timeLeft = parseInt("{{timeLeft}}");
        const timerElement = document.getElementById('timer');

        const interval = setInterval(() => {
            const mins = Math.floor(timeLeft / 60);
            const secs = timeLeft % 60;
            timerElement.innerText = `${mins}:${secs < 10 ? '0' : ''}${secs}`;

            if (timeLeft <= 0) {
                clearInterval(interval);
                timerElement.innerText = "0:00";
                {{#if isHost}}
                    // O Host continua a ser o responsável por disparar a mudança de fase
                    fetch('/theme/vote/start', { method: 'POST' });
                {{/if}}
            }
            timeLeft--;
        }, 1000);
    </script>
</body>
</html>