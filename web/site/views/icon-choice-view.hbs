<!DOCTYPE html>
<html lang="pt-pt">
<head>
    <meta charset="UTF-8">
    <title>GIFWARS - Escolhe o teu Ícone</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="p-4 md:p-8 flex items-center justify-center min-h-screen">

    <main class="max-w-2xl w-full">
        <div class="glass p-10 md:p-16 rounded-[48px] border-t border-white/10 shadow-2xl relative overflow-hidden text-center">
            
            <div class="mb-10">
                <h2 class="text-4xl font-black italic text-white mb-2 uppercase tracking-tighter">Escolhe o teu Avatar</h2>
                <p class="text-purple-400 font-bold uppercase tracking-[0.3em] text-[10px] italic italic">Prepara a tua imagem para a Batalha</p>
            </div>

            <form action="/profile/update" method="POST" class="space-y-12">
                <!-- SE VIER DO PERFIL, VOLTA AO PERFIL; CASO CONTRÁRIO, VAI PARA A ARENA -->
                <input type="hidden" name="redirect" value="{{#if fromProfile}}/profile{{else}}/{{/if}}">

                <div class="grid grid-cols-2 sm:grid-cols-5 gap-4">
                    {{#each pfpList}}
                    <label class="cursor-pointer group">
                        <input type="radio" name="pfp" value="{{this}}" class="hidden peer" {{#if (eq (string this) (string ../player.pfp))}}checked{{/if}}>
                        
                        <div class="aspect-square rounded-3xl bg-black/40 border-2 border-transparent peer-checked:border-purple-500 peer-checked:bg-purple-500/10 group-hover:bg-white/5 transition-all p-3 flex items-center justify-center relative overflow-hidden">
                            <img src="/images/pfp-{{this}}.jpeg" class="w-full h-full object-contain filter grayscale group-hover:grayscale-0 peer-checked:grayscale-0 transition-all duration-300" alt="Icon {{this}}">
                            
                            <div class="absolute inset-0 bg-purple-600/10 opacity-0 peer-checked:opacity-100 transition-opacity"></div>
                            
                            <div class="absolute -top-1 -right-1 w-6 h-6 bg-purple-500 rounded-full items-center justify-center hidden peer-checked:flex shadow-lg z-20">
                                <i data-lucide="check" class="w-4 h-4 text-white"></i>
                            </div>
                        </div>
                    </label>
                    {{/each}}
                </div>

                <div class="pt-4">
                    <button type="submit" class="w-full bg-white text-black p-6 rounded-3xl font-black text-xl hover:bg-purple-600 hover:text-white transition-all shadow-xl active:scale-95 uppercase italic tracking-tight">
                        CONFIRMAR GUERREIRO
                    </button>
                    <a href="{{#if fromProfile}}/profile{{else}}/{{/if}}" class="block mt-6 text-gray-500 font-bold uppercase text-[10px] tracking-widest hover:text-white transition-colors italic">Cancelar</a>
                </div>
            </form>
        </div>
    </main>

    <script src="https://unpkg.com/lucide@latest"></script>
    <script>lucide.createIcons();</script>
</body>
</html>