<!DOCTYPE html>
<html lang="pt-pt">
<head>
    <meta charset="UTF-8">
    <title>GIFWARS - O Teu Perfil</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="p-4 md:p-8">

    {{> header}}

    <main class="max-w-2xl mx-auto mt-20">
        <div class="glass p-12 rounded-[48px] border-t border-white/10 shadow-2xl relative overflow-hidden">
            <div class="absolute inset-0 bg-purple-600/5 pointer-events-none"></div>
            
            <div class="relative z-10 text-center">
                <div class="mb-10 flex flex-col items-center">
                    <a href="/choose-icon?from=profile" class="w-32 h-32 rounded-[40px] bg-gradient-to-tr from-purple-600 to-pink-500 p-1 shadow-2xl mb-6 relative group border border-white/10 block transition-transform hover:scale-105 active:scale-95">
                        <div class="w-full h-full bg-gray-900 rounded-[38px] flex items-center justify-center overflow-hidden">
                            <img src="/images/pfp-{{player.pfp}}.jpeg" class="w-full h-full object-contain" onerror="this.src='https://placehold.co/100?text=Avatar'">
                        </div>
                        <div class="absolute inset-0 bg-black/60 rounded-[40px] opacity-0 group-hover:opacity-100 transition-opacity flex flex-col items-center justify-center gap-2">
                            <i data-lucide="camera" class="w-6 h-6 text-white"></i>
                            <span class="text-[8px] font-black text-white uppercase italic tracking-widest">Alterar Avatar</span>
                        </div>
                    </a>

                    <h2 class="text-4xl font-black italic mb-2 uppercase tracking-tighter">O Teu Perfil</h2>
                    <p class="text-gray-500 text-[10px] font-bold uppercase tracking-[0.3em] italic">Arena de Batalha 2026</p>
                </div>

                <form action="/profile/update" method="POST" class="space-y-10">
                    <input type="hidden" name="redirect" value="/">
                    
                    <div class="space-y-2 text-left">
                        <label class="text-[10px] font-black text-purple-400 uppercase tracking-[0.3em] ml-6 italic">Nome de Guerra</label>
                        <input 
                            type="text" 
                            name="name" 
                            value="{{player.name}}" 
                            maxlength="15" 
                            required 
                            class="w-full p-6 bg-gray-900 border-2 border-gray-800 rounded-3xl text-white text-center text-2xl font-black focus:border-purple-600 outline-none transition-all"
                        >
                    </div>

                    <div class="flex flex-col gap-4">
                        <button type="submit" class="w-full bg-white text-black p-6 rounded-3xl font-black text-xl hover:bg-purple-600 hover:text-white transition-all shadow-xl active:scale-95 uppercase italic">
                            GUARDAR ALTERAÇÕES
                        </button>
                        
                        {{#if player.roomId}}
                            <form action="/room/leave" method="POST" class="w-full">
                                <button type="submit" formmethod="POST" formaction="/room/leave" class="w-full bg-red-500/10 border border-red-500/20 text-red-500 p-5 rounded-3xl font-black text-xs hover:bg-red-500 hover:text-white transition-all uppercase tracking-[0.2em] italic">
                                    ABANDONAR SALA ATUAL
                                </button>
                            </form>
                        {{/if}}

                        <a href="/" class="text-gray-600 font-bold uppercase text-[10px] tracking-widest hover:text-white transition-colors italic mt-4">
                            VOLTAR À ARENA
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </main>

    {{> footer}}

</body>
</html>