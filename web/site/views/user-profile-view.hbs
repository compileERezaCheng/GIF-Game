<!DOCTYPE html>
<html lang="pt-pt">
<head>
    <meta charset="UTF-8">
    <title>GIFWARS - O Teu Perfil</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="p-4 md:p-8">

    {{> header}}

    <main class="max-w-2xl mx-auto mt-20">
        <div class="glass p-12 rounded-[48px] border-t border-white/10 shadow-2xl relative overflow-hidden">
            <div class="absolute inset-0 bg-purple-600/5 pointer-events-none"></div>
            
            <div class="relative z-10 text-center">
                <div class="mb-10 flex justify-center">
                    <div class="w-24 h-24 rounded-3xl bg-gradient-to-tr from-purple-600 to-pink-500 flex items-center justify-center shadow-2xl rotate-3">
                        <i data-lucide="user" class="w-12 h-12 text-white"></i>
                    </div>
                </div>

                <h2 class="text-4xl font-black italic mb-2 uppercase tracking-tighter">O Teu Perfil</h2>
                <p class="text-gray-500 text-sm mb-12 italic uppercase tracking-widest">Altera a tua identidade na Arena</p>

                <form action="/profile/update" method="POST" class="space-y-8">
                    <div class="space-y-2 text-left">
                        <label class="text-[10px] font-black text-purple-400 uppercase tracking-[0.3em] ml-4">Novo Nome de Guerra</label>
                        <input 
                            type="text" 
                            name="name" 
                            value="{{player.name}}" 
                            maxlength="15" 
                            required 
                            class="w-full p-6 bg-gray-900 border-2 border-gray-800 rounded-3xl text-white text-center text-2xl font-black focus:border-purple-600 focus:bg-black outline-none transition-all"
                        >
                    </div>

                    <div class="flex flex-col gap-4">
                        <button type="submit" class="w-full bg-white text-black p-6 rounded-3xl font-black text-xl hover:bg-purple-600 hover:text-white transition-all shadow-xl active:scale-95">
                            GUARDAR ALTERAÇÕES
                        </button>
                        <a href="/" class="text-gray-600 font-bold uppercase text-[10px] tracking-widest hover:text-white transition-colors">
                            Cancelar e Voltar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </main>

    {{> footer}}

</body>
</html>