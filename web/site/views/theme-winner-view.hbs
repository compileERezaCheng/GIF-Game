<!DOCTYPE html>
<html lang="pt-pt">
<head>
    <meta charset="UTF-8">
    <title>GIFWARS - Tema Vencedor</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="p-4 md:p-8">

    {{> header}}

    <span id="room-code-display" class="hidden">{{room.code}}</span>

    <main class="max-w-4xl mx-auto mt-20 text-center">
        <div class="glass p-16 rounded-[48px] border-t-8 border-yellow-500 shadow-2xl relative overflow-hidden max-w-2xl mx-auto">
            <div class="absolute -top-20 -left-20 w-60 h-60 bg-yellow-500/10 rounded-full blur-[80px]"></div>
            
            <div class="relative z-10">
                <div class="inline-flex p-4 bg-yellow-500/10 rounded-2xl mb-8">
                    <!-- Ícone de Troféu -->
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#eab308" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"></path><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"></path><path d="M4 22h16"></path><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"></path><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"></path><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"></path></svg>
                </div>
                
                <h3 class="text-purple-400 font-black uppercase tracking-[0.4em] mb-4 text-xs italic">O Tema Escolhido é...</h3>
                <h2 class="text-5xl md:text-6xl font-black italic text-white mb-12 uppercase leading-tight drop-shadow-2xl">
                    "{{theme}}"
                </h2>
                
                <div class="flex flex-col items-center gap-4">
                    <div class="w-full bg-white/5 h-2 rounded-full overflow-hidden">
                        <div id="progress-bar" class="bg-yellow-500 h-full w-full transition-all duration-[5000ms] ease-linear"></div>
                    </div>
                    <p class="text-gray-500 text-xs font-bold uppercase tracking-widest italic">
                        A começar batalha em <span id="countdown-text">5</span>s...
                    </p>
                </div>
            </div>
        </div>
    </main>

    {{> footer}}

    <script src="/socket.io/socket.io.js"></script>
    <script>
        (function() {
            const socket = io();
            socket.emit('join_room_socket', '{{room.code}}');

            socket.on('room_sync', (data) => {
                if (data.type === 'state_update') {
                    window.location.reload();
                }
            });

            let seconds = parseInt("{{timeLeft}}") || 5;
            const textEl = document.getElementById('countdown-text');
            const barEl = document.getElementById('progress-bar');
            let triggered = false;

            // Inicia a animação da barra
            setTimeout(() => { 
                if(barEl) {
                    barEl.style.transitionDuration = (seconds * 1000) + 'ms';
                    barEl.style.width = '0%'; 
                }
            }, 50);

            const timer = setInterval(() => {
                seconds--;
                if(textEl) textEl.innerText = Math.max(0, seconds);

                if (seconds <= 0) {
                    clearInterval(timer);
                    {{#if isHost}}
                        if(!triggered) {
                            triggered = true;
                            // CORREÇÃO: Chamar a rota genérica de avanço que já trata THEME_WINNER
                            fetch('/game/auto-advance', { method: 'POST' })
                                .then(res => res.json())
                                .then(data => {
                                    if(!data.success) triggered = false;
                                });
                        }
                    {{/if}}
                }
            }, 1000);
        })();
    </script>
</body>
</html>