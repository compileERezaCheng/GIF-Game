<!DOCTYPE html>
<html lang="pt-pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GIFWARS - Duelo de Temas</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="p-4 md:p-8">
    {{> header}}
    <main class="max-w-4xl mx-auto mt-10 text-center">
        <div class="mb-8 flex justify-center">
            <div class="w-20 h-20 rounded-full border-4 border-purple-500 flex items-center justify-center bg-black/40 shadow-xl">
                <span id="timer" class="text-2xl font-black text-white">--</span>
            </div>
        </div>
        <div class="mb-10">
            <h2 class="text-4xl font-black italic mb-2 text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-pink-500 uppercase">DUELO DE TEMAS</h2>
            <p class="text-gray-400 uppercase tracking-widest text-xs font-bold italic">Escolhe o teu destino!</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-3xl mx-auto px-4">
            {{#each ballot}}
            <form action="/theme/vote" method="POST" class="h-full">
                <input type="hidden" name="tema" value="{{this}}">
                <button type="submit" class="w-full h-full glass p-12 rounded-[40px] text-3xl font-black hover:bg-purple-600 hover:scale-105 transition-all border-b-8 border-purple-900 active:border-b-0 active:translate-y-2 flex items-center justify-center min-h-[250px] shadow-2xl">
                    {{this}}
                </button>
            </form>
            {{/each}}
        </div>
    </main>
    {{> footer}}
    <script src="/socket.io/socket.io.js"></script>
    <script>
        (function() {
            const timerElement = document.getElementById('timer');
            let timeLeft = parseInt("{{timeLeft}}") || 0;
            function updateDisplay() { timerElement.innerText = Math.max(0, timeLeft) + "s"; }
            updateDisplay();
            const interval = setInterval(() => {
                timeLeft--; updateDisplay();
                if (timeLeft <= 0) {
                    clearInterval(interval);
                    {{#if isHost}} fetch('/theme/vote-auto-finish', { method: 'POST' }); {{/if}}
                }
            }, 1000);
            const socket = io();
            socket.emit('join_room_socket', '{{room.code}}');
            socket.on('room_sync', (data) => { if (data.type === 'state_update') window.location.reload(); });
        })();
    </script>
</body>
</html>