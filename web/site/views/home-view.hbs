<!DOCTYPE html>
<html lang="pt-pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GIFWARS - Arena</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="p-4 md:p-8">

    {{> header}}

    <main class="max-w-4xl mx-auto min-h-[60vh]">
        
        <!-- SECÇÃO: LOGIN -->
        <section id="section-join" class="glass rounded-3xl p-8 text-center max-w-md mx-auto mt-10">
            <i data-lucide="user-circle" class="w-16 h-16 mx-auto mb-4 text-purple-500"></i>
            <h2 class="text-2xl font-bold mb-2">Entrar na Arena</h2>
            <p class="text-gray-400 mb-6">Escolhe o teu nome de guerra.</p>
            <input type="text" id="input-name" placeholder="Teu nome..." class="w-full bg-gray-800 border border-gray-700 rounded-xl px-4 py-3 mb-4 focus:outline-none focus:ring-2 focus:ring-purple-500 text-center text-lg text-white">
            <button onclick="joinGame()" class="w-full bg-purple-600 hover:bg-purple-700 text-white font-bold py-4 rounded-xl transition-all shadow-lg shadow-purple-900/20">
                Confirmar Presença
            </button>
        </section>

        <!-- SECÇÃO: ESPERA -->
        <section id="section-waiting" class="hidden space-y-6">
            <div class="glass rounded-3xl p-8 text-center">
                <h2 class="text-2xl font-bold mb-2">Sala de Espera</h2>
                <p id="round-display" class="text-purple-400 text-sm font-bold uppercase mb-6"></p>
                <div class="flex gap-2 max-w-md mx-auto">
                    <input type="text" id="input-suggestion" placeholder="Sugere um tema..." class="flex-1 bg-gray-800 border border-gray-700 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-purple-500 text-white">
                    <button onclick="sendSuggestion()" class="bg-purple-600 px-6 rounded-xl hover:bg-purple-700 font-bold">Enviar</button>
                </div>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="glass rounded-3xl p-6">
                    <h3 class="font-bold mb-4 flex items-center gap-2"><i data-lucide="users" class="w-5 h-5"></i> Jogadores (<span id="count-players">0</span>)</h3>
                    <ul id="list-players" class="space-y-2 text-sm"></ul>
                    <button id="btn-start" onclick="requestStart()" class="hidden mt-6 w-full bg-green-600 py-3 rounded-xl font-bold hover:bg-green-700 transition-colors">Iniciar Ronda</button>
                </div>
                <div class="glass rounded-3xl p-6">
                    <h3 class="font-bold mb-4 flex items-center gap-2"><i data-lucide="lightbulb" class="w-5 h-5"></i> Pool de Temas</h3>
                    <div id="list-suggestions" class="flex flex-wrap gap-2"></div>
                </div>
            </div>
        </section>

        <!-- SECÇÃO: VOTAÇÃO DE TEMA (BALLOT) -->
        <section id="section-theme-vote" class="hidden text-center py-10">
            <h2 class="text-3xl font-black mb-2 italic">QUAL O TEMA?</h2>
            <p class="text-gray-400 mb-10">Os jogadores decidem o destino da ronda.</p>
            <div id="ballot-container" class="grid grid-cols-1 md:grid-cols-2 gap-6"></div>
        </section>

        <!-- SECÇÃO: JOGO (PLAYING) -->
        <section id="section-playing" class="hidden glass rounded-3xl p-8 text-center border-t-4 border-purple-500">
            <div class="mb-10">
                <span class="text-purple-400 text-xs font-bold uppercase tracking-widest bg-purple-500/10 px-3 py-1 rounded-full">Tema Ativo</span>
                <h2 id="display-theme" class="text-4xl font-black mt-4 uppercase italic"></h2>
            </div>
            <div class="max-w-lg mx-auto space-y-6">
                <input type="text" id="input-gif" placeholder="Cola aqui o link do GIF..." class="w-full bg-gray-800 border border-gray-700 rounded-xl px-4 py-4 focus:outline-none focus:ring-2 focus:ring-purple-500 text-white text-center">
                <div id="gif-preview-container" class="hidden rounded-2xl overflow-hidden bg-black border border-gray-700 shadow-2xl">
                    <img id="img-preview" src="" class="w-full h-auto">
                </div>
                <button onclick="submitGif()" class="w-full bg-purple-600 py-4 rounded-xl font-bold hover:bg-purple-700 text-lg shadow-lg">Submeter Resposta</button>
            </div>
        </section>

        <!-- SECÇÃO: VOTAR GIFS -->
        <section id="section-voting" class="hidden">
            <h2 class="text-3xl font-black mb-8 text-center italic">VOTA NO TEU FAVORITO</h2>
            <div id="voting-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"></div>
        </section>

        <!-- SECÇÃO: RESULTADOS -->
        <section id="section-results" class="hidden space-y-10">
            <div class="text-center">
                <h2 class="text-5xl font-black italic text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-pink-500">PODIUM</h2>
                <div id="winner-theme-display" class="text-gray-400 mt-2"></div>
            </div>
            <div id="results-list" class="space-y-4"></div>
            <button onclick="location.reload()" class="w-full glass py-4 rounded-xl font-bold hover:bg-white/10 transition-all uppercase tracking-widest text-sm">
                Voltar ao Lobby
            </button>
        </section>

    </main>

    {{> footer}}

    <!-- Logic Client-Side -->
    <script>
        const socket = io();
        let myId = null;
        let currentStatus = "";

        async function sync() {
            const r = await fetch('/api/game');
            const game = await r.json();
            handleStatusChange(game);
        }

        function handleStatusChange(game) {
            const status = game.status;
            document.getElementById('game-status-badge').innerText = status;
            
            const sections = ['join', 'waiting', 'theme-vote', 'playing', 'voting', 'results'];
            sections.forEach(s => document.getElementById('section-' + s).classList.add('hidden'));

            if (!myId && status !== 'waiting') {
                document.getElementById('section-join').classList.remove('hidden');
                return;
            }

            const active = document.getElementById('section-' + (status === 'selecting_theme' ? 'theme-vote' : status));
            if (active) active.classList.remove('hidden');

            // Updates específicos por fase
            if (status === 'waiting') {
                document.getElementById('round-display').innerText = `Ronda ${game.round}`;
                updatePlayers();
                updateSuggestions();
            } else if (status === 'selecting_theme') {
                renderThemeBallot(game.themeBallot);
            } else if (status === 'playing') {
                document.getElementById('display-theme').innerText = game.currentTheme;
            } else if (status === 'voting') {
                renderGifsToVote();
            } else if (status === 'results') {
                renderFinalResults();
            }
        }

        async function updatePlayers() {
            const r = await fetch('/api/players');
            const players = await r.json();
            document.getElementById('count-players').innerText = players.length;
            document.getElementById('list-players').innerHTML = players.map(p => `
                <li class="flex justify-between items-center glass p-3 rounded-xl border-l-4 ${p.id === socket.id ? 'border-purple-500' : 'border-transparent'}">
                    <span class="font-semibold">${p.name} ${p.id === socket.id ? '(Tu)' : ''}</span>
                    <span class="bg-purple-600/20 text-purple-400 px-2 py-0.5 rounded text-xs font-bold">${p.score} PTS</span>
                </li>
            `).join('');
            if (players.length >= 2) document.getElementById('btn-start').classList.remove('hidden');
        }

        async function updateSuggestions() {
            const r = await fetch('/api/themes/suggestions');
            const sugs = await r.json();
            document.getElementById('list-suggestions').innerHTML = sugs.map(s => `
                <span class="bg-white/5 border border-white/10 px-3 py-1 rounded-full text-xs text-gray-300">${s}</span>
            `).join('');
        }

        function joinGame() {
            const name = document.getElementById('input-name').value;
            if(!name) return showToast("Mete um nome!");
            socket.emit('join_game', name);
            myId = socket.id;
            document.getElementById('player-badge').classList.remove('hidden');
            document.getElementById('player-name-display').innerText = name;
            sync();
        }

        function sendSuggestion() {
            const tema = document.getElementById('input-suggestion').value;
            if(!tema) return;
            fetch('/api/themes/suggest', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({tema})
            }).then(() => {
                document.getElementById('input-suggestion').value = "";
                showToast("Tema sugerido!");
                updateSuggestions();
            });
        }

        function requestStart() { socket.emit('start_game'); }

        function renderThemeBallot(ballot) {
            const container = document.getElementById('ballot-container');
            container.innerHTML = ballot.map(t => `
                <button onclick="voteTheme('${t}')" class="glass p-8 rounded-3xl text-xl font-bold hover:bg-purple-600 hover:scale-105 transition-all">
                    ${t}
                </button>
            `).join('');
        }

        function voteTheme(tema) {
            fetch('/api/themes/vote', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({playerId: socket.id, tema})
            }).then(() => {
                showToast("Voto no tema enviado!");
                document.getElementById('ballot-container').innerHTML = "<p class='col-span-full opacity-50 italic py-10'>A aguardar que os outros votem...</p>";
            });
        }

        async function submitGif() {
            const url = document.getElementById('input-gif').value;
            const res = await fetch('/api/gifs', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({playerId: socket.id, url})
            });
            const data = await res.json();
            if(data.error) showToast(data.error);
            else {
                showToast("GIF enviado com sucesso!");
                document.getElementById('section-playing').innerHTML = "<h2 class='text-2xl font-bold'>GIF Submetido! 🚀</h2><p class='text-gray-400'>Prepara-te para a votação.</p>";
            }
        }

        async function renderGifsToVote() {
            const r = await fetch('/api/gifs');
            const gifs = await r.json();
            document.getElementById('voting-grid').innerHTML = gifs.map(g => `
                <div onclick="castGifVote('${g.id}')" class="gif-card glass rounded-2xl overflow-hidden cursor-pointer">
                    <img src="${g.url}" class="w-full aspect-square object-cover bg-black" onerror="this.src='https://placehold.co/400?text=Erro+Imagem'">
                    <div class="p-4 text-center font-bold text-sm bg-purple-600 hover:bg-purple-500 transition-colors uppercase">Escolher este</div>
                </div>
            `).join('');
        }

        function castGifVote(gifId) {
            fetch('/api/votes', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({playerId: socket.id, gifId})
            }).then(async r => {
                const d = await r.json();
                if(d.error) showToast(d.error);
                else {
                    showToast("Voto registado!");
                    document.getElementById('voting-grid').innerHTML = "<p class='col-span-full text-center py-20 opacity-50'>Voto confirmado. Aguarda pelos resultados finais...</p>";
                }
            });
        }

        async function renderFinalResults() {
            const r = await fetch('/api/results');
            const data = await r.json();
            document.getElementById('winner-theme-display').innerText = `Tema: ${data.tema}`;
            document.getElementById('results-list').innerHTML = data.resultados.map((res, i) => `
                <div class="glass p-4 rounded-2xl flex items-center gap-4 ${i === 0 ? 'border-2 border-yellow-500/50' : ''}">
                    <div class="text-2xl font-black ${i === 0 ? 'text-yellow-500' : 'text-gray-600'}">#${i+1}</div>
                    <img src="${res.url}" class="w-20 h-20 rounded-lg object-cover bg-black">
                    <div class="flex-1">
                        <div class="font-bold">${res.dono}</div>
                        <div class="text-xs text-gray-400">${res.totalVotos} votos de: ${res.quemVotou.join(', ')}</div>
                    </div>
                </div>
            `).join('');
        }

        // Preview de GIF real-time
        document.getElementById('input-gif')?.addEventListener('input', (e) => {
            const url = e.target.value;
            const preview = document.getElementById('gif-preview-container');
            const img = document.getElementById('img-preview');
            if(url.startsWith('http')) {
                preview.classList.remove('hidden');
                img.src = url;
            } else {
                preview.classList.add('hidden');
            }
        });

        socket.on('game_started', sync);
        socket.on('theme_selected', sync);
        socket.on('update_players', updatePlayers);
        setInterval(sync, 5000); // Polling de redundância
    </script>
</body>
</html>